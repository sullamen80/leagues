rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && (
        userDoc().data.isAdmin == true || userDoc().data.admin == true
      );
    }

    function isChangingAdminFields() {
      return request.resource.data.diff(resource.data).changedKeys().hasAny([
        'isAdmin',
        'admin'
      ]);
    }

    function leagueDoc(leagueId) {
      return get(/databases/$(database)/documents/leagues/$(leagueId));
    }

    function isLeagueOwner(leagueId) {
      return isSignedIn() && leagueDoc(leagueId).data.ownerId == request.auth.uid;
    }

    function isLeagueMember(leagueId) {
      return isSignedIn()
        && leagueDoc(leagueId).data.members != null
        && request.auth.uid in leagueDoc(leagueId).data.members;
    }

    function isOwnerOrAdmin(leagueId) {
      return isLeagueOwner(leagueId) || isAdmin();
    }

    function isLeagueJoinRequest() {
      return isSignedIn()
        && resource.data.private != true
        && resource.data.passwordProtected != true
        && request.resource.data.members != null
        && resource.data.members != null
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'members',
          'users',
          'updatedAt'
        ])
        && request.resource.data.members.size() == resource.data.members.size() + 1
        && request.resource.data.members.hasAll(resource.data.members)
        && request.auth.uid in request.resource.data.members;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && userId == request.auth.uid
        && !request.resource.data.keys().hasAny(['isAdmin', 'admin']);
      allow update: if isSignedIn() && (
        (userId == request.auth.uid && !isChangingAdminFields())
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /gameStats/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /{subcollection}/{subDocId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    match /statsHistory/{leagueKey} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /{document=**} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwnerOrAdmin(leagueId)
        && (request.resource.data.ownerId == resource.data.ownerId || isAdmin())
        || isLeagueJoinRequest();
      allow delete: if isOwnerOrAdmin(leagueId);

      match /userData/{userId} {
        allow read: if isLeagueMember(leagueId) || isOwnerOrAdmin(leagueId);
        allow create: if isOwnerOrAdmin(leagueId)
          || (isSignedIn() && request.auth.uid == userId && isLeagueMember(leagueId));
        allow update: if isOwnerOrAdmin(leagueId)
          || (isSignedIn() && request.auth.uid == userId && isLeagueMember(leagueId));
        allow delete: if isOwnerOrAdmin(leagueId);
      }

      match /{subcollection}/{docId} {
        allow read: if isLeagueMember(leagueId) || isOwnerOrAdmin(leagueId);
        allow write: if isOwnerOrAdmin(leagueId);
      }
    }
  }
}
